[configuration]
entry_symbol = "godotvehicles_library_init"
compatibility_minimum = 4.6

[libraries]
macos.debug.arm64 = "res://bin/macos/arm64/libGodotVehicles.dylib"
macos.release.arm64 = "res://bin/macos/arm64/libGodotVehicles.dylib"
windows.debug.x86_64 = "res://bin/windows/GodotVehicles.dll"
windows.release.x86_64 = "res://bin/windows/GodotVehicles.dll"
linux.debug.x86_64 = "res://bin/linux/libGodotVehicles.so"
linux.release.x86_64 = "res://bin/linux/libGodotVehicles.so"